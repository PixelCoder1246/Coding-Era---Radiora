
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  DOCTOR
}

enum IntegrationType {
  PACS
  HIS
}

enum CaseStatus {
  UNASSIGNED
  PENDING_REVIEW
  IN_REVIEW
  COMPLETED
}

enum AiStatus {
  NOT_REQUESTED
  PROCESSING
  COMPLETED
  FAILED
}

model User {
  id                  String   @id @default(cuid())
  name                String
  email               String   @unique
  passwordHash        String
  role                Role     @default(DOCTOR)
  maxConcurrentCases  Int      @default(5)
  createdByAdminId    String?
  createdAt           DateTime @default(now())
  assignedCases       Case[]
  reports             Report[]
}

model Integration {
  id                  String          @id @default(cuid())
  adminId             String
  type                IntegrationType
  url                 String
  username            String?
  password            String?
  apiKey              String?
  pollIntervalSeconds Int?
  active              Boolean         @default(false)
  activatedAt         DateTime?
  updatedAt           DateTime        @updatedAt

  @@unique([adminId, type])
}

model Case {
  id               String     @id @default(cuid())
  adminId          String
  orthancId        String
  studyInstanceUID String     @unique
  accessionNumber  String
  patientId        String
  patientName      String
  patientEmail     String?
  patientPhone     String?
  modality         String
  bodyPart         String?
  studyDate        DateTime?
  status           CaseStatus @default(UNASSIGNED)
  assignedDoctorId String?
  assignedDoctor   User?      @relation(fields: [assignedDoctorId], references: [id])
  aiStatus         AiStatus   @default(NOT_REQUESTED)
  aiResult         AiResult?
  report           Report?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}

model ProcessedStudy {
  id               String   @id @default(cuid())
  adminId          String
  studyInstanceUID String
  processedAt      DateTime @default(now())

  @@unique([adminId, studyInstanceUID])
}

model Report {
  id          String   @id @default(cuid())
  caseId      String   @unique
  doctorId    String
  reportText  String
  impression  String?
  accessToken String   @unique
  submittedAt DateTime @default(now())

  case   Case @relation(fields: [caseId], references: [id])
  doctor User @relation(fields: [doctorId], references: [id])
}

model AiResult {
  id          String   @id @default(cuid())
  caseId      String   @unique
  findings    String
  confidence  Float
  annotations Json
  analyzedAt  DateTime @default(now())

  case Case @relation(fields: [caseId], references: [id])
}
